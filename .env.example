# Copy to .env.local and fill in. NEVER commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Supabase Dashboard > Settings > API. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
# Used only by scripts/seed-catalog.mjs (demo admin account)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Toast POS — standard API access (ver docs/INTEGRACIONES.md)
TOAST_API_HOST=https://ws-api.toasttab.com
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=
# Sales ingestion: HMAC secret from the Toast webhook subscription (order_updated).
# The poll cron reuses CRON_SECRET (defined below).
TOAST_WEBHOOK_SECRET=

# Shopify — custom app Admin API (ver docs/INTEGRACIONES.md)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01

# Reporte nocturno del removal log (ver docs/REMOVAL_HANDOFF.md)
# Resend. El remitente debe estar en un dominio verificado en Resend.
RESEND_API_KEY=
REMOVAL_REPORT_FROM=SWR Reports <hola@ekinoxis.xyz>
# Los destinatarios los gestiona el master admin desde /users (tabla en la base).
# Esta env var es solo un RESPALDO: se usa únicamente si esa lista está vacía.
REMOVAL_REPORT_TO=
# Secreto del cron de Vercel. Vercel lo manda como `Authorization: Bearer <valor>`.
CRON_SECRET=
